{
  "name": "@liuhuakawaii/dep-radar",
  "version": "0.1.3",
  "description": "前端依赖雷达 — 一站式依赖分析与优化建议 CLI 工具",
  "type": "module",
  "packageManager": "pnpm@10.18.3",
  "repository": {
    "type": "git",
    "url": "https://github.com/liuhuakawaii/dep-radar.git"
  },
  "bin": {
    "dep-radar": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,json}\"",
    "typecheck": "tsc --noEmit",
    "prepare": "husky",
    "preinstall": "npx only-allow pnpm",
    "prepublishOnly": "pnpm run typecheck && pnpm run lint && pnpm run test && pnpm run build"
  },
  "keywords": [
    "cli",
    "dependency",
    "analyzer",
    "bundle",
    "security",
    "license",
    "npm",
    "optimization",
    "前端依赖",
    "包体积分析"
  ],
  "author": "liuhuakawaii",
  "license": "MIT",
  "engines": {
    "node": ">=18.17.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "boxen": "^8.0.0",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "consola": "^3.2.3",
    "cosmiconfig": "^9.0.0",
    "env-paths": "^3.0.0",
    "fast-glob": "^3.3.3",
    "js-yaml": "^4.2.0",
    "ora": "^8.1.0",
    "p-limit": "^6.1.0",
    "semver": "^7.6.3",
    "spdx-expression-parse": "^4.0.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@eslint/js": "^9.12.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.16.0",
    "@types/semver": "^7.5.0",
    "@types/spdx-expression-parse": "^4.0.0",
    "@vitest/coverage-v8": "^2.1.0",
    "eslint": "^9.12.0",
    "globals": "^15.10.0",
    "husky": "^9.1.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.3.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.8.0",
    "vitest": "^2.1.0"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
